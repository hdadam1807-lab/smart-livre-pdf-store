        <section id="page-dashboard" class="hidden">
            <h2 style="margin: 30px 0; border-right: 5px solid var(--accent-orange); padding-right: 15px;">لوحة تحكم مشاريعي 📁</h2>
            <div id="myFilesGrid" class="books-grid"></div>
        </section>
    </div>

    <div id="uploadModal" class="modal-overlay hidden">
        <div class="auth-box" style="max-width: 550px;">
            <h2 style="color: var(--accent-orange); margin-bottom: 15px;">نشر منتج رقمي جديد 🚀</h2>
            
